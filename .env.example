# Finansijski handoff (SFTP destinacija po zemlji)
HANDOFF_MNE_TARGET=""
HANDOFF_SRB_TARGET=""
HANDOFF_HRV_TARGET=""
HANDOFF_BIH_TARGET=""

# Notifikacije (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
