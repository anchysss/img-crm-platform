// IMG CRM Platform — Prisma schema
// Sve domenske tabele imaju pravnoLiceId (ADR-0002) + createdAt/updatedAt/deletedAt? + createdBy/updatedBy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// Tenancy & Auth
// =============================================================

model PravnoLice {
  id            String   @id @default(cuid())
  kod           String   @unique // MNE | SRB | HRV | BIH
  naziv         String
  zemlja        String // ISO 3166-1 alpha-2
  valuta        String // ISO 4217
  pib           String
  tz            String   @default("Europe/Podgorica")
  jezik         String   @default("sr-Latn")
  sablonFakture String   @default("default") // identifikator šablona
  stopaPdv      Decimal  @default("0") @db.Decimal(5, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  korisnici      KorisnikRola[]
  partneri       Partner[]
  opportunities  Opportunity[]
  kampanje       Kampanja[]
  vozila         Vozilo[]
  dokumenti      Dokument[]
  numeracija     NumeracijaSkok[]
  handoffBatches HandoffBatch[]
  auditLog       AuditLog[]
  notifikacije   Notifikacija[]
}

model Korisnik {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  ime                 String
  prezime             String
  aktivan             Boolean   @default(true)
  twoFaSecret         String? // TOTP secret; null dok nije podešen
  twoFaEnabled        Boolean   @default(false)
  lastLoginAt         DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  roles        KorisnikRola[]
  vlasnikOpp   Opportunity[]         @relation("OpportunityVlasnik")
  aktivnosti   Aktivnost[]
  auditLog     AuditLog[]
  notifikacije Notifikacija[]
  sessions     Session[]
  piiAccess    LicniPodatakPristup[]

  @@index([email])
  @@index([aktivan])
}

model Rola {
  id    String  @id @default(cuid())
  kod   RolaKod @unique // fiksan enum; PZ 4.2 (strogi FK, nema slobodnog teksta)
  naziv String
  opis  String?

  dozvole       Dozvola[]
  korisniciRole KorisnikRola[]
}

enum RolaKod {
  ADMIN
  COUNTRY_MANAGER
  SALES_MANAGER
  SALES_REP
  FINANCE
  READ_ONLY
}

model KorisnikRola {
  id           String @id @default(cuid())
  korisnikId   String
  rolaId       String
  pravnoLiceId String

  korisnik   Korisnik   @relation(fields: [korisnikId], references: [id], onDelete: Cascade)
  rola       Rola       @relation(fields: [rolaId], references: [id])
  pravnoLice PravnoLice @relation(fields: [pravnoLiceId], references: [id])

  createdAt DateTime @default(now())

  @@unique([korisnikId, rolaId, pravnoLiceId])
  @@index([korisnikId])
  @@index([pravnoLiceId])
}

model Dozvola {
  id     String        @id @default(cuid())
  rolaId String
  modul  String // npr. "partners", "opportunities", ...
  akcija AkcijaDozvole

  rola Rola @relation(fields: [rolaId], references: [id], onDelete: Cascade)

  @@unique([rolaId, modul, akcija])
  @@index([modul, akcija])
}

enum AkcijaDozvole {
  READ
  CREATE
  UPDATE
  DELETE
  EXPORT
  APPROVE
}

model Session {
  id         String   @id @default(cuid())
  korisnikId String
  token      String   @unique
  ip         String?
  userAgent  String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  korisnik Korisnik @relation(fields: [korisnikId], references: [id], onDelete: Cascade)

  @@index([korisnikId])
  @@index([expiresAt])
}

// =============================================================
// Komercijalni
// =============================================================

model Partner {
  id           String        @id @default(cuid())
  pravnoLiceId String
  naziv        String
  tip          PartnerTip
  segment      Segment       @default(C)
  status       PartnerStatus @default(AKTIVAN)
  maticniBroj  String?
  pibVat       String?
  zemlja       String
  adresa       String?
  grad         String?
  napomene     String?
  vlasnikId    String? // Sales Rep
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  createdBy    String?
  updatedBy    String?

  pravnoLice    PravnoLice    @relation(fields: [pravnoLiceId], references: [id])
  kontakti      Kontakt[]
  opportunities Opportunity[]
  kampanje      Kampanja[]
  dokumenti     Dokument[]
  aktivnosti    Aktivnost[]

  @@index([pravnoLiceId])
  @@index([tip])
  @@index([segment])
  @@index([vlasnikId])
}

enum PartnerTip {
  DIRECT
  AGENCY
  RESELLER
  PROVIDER
}

enum Segment {
  A
  B
  C
}

enum PartnerStatus {
  AKTIVAN
  NEAKTIVAN
  BLOKIRAN
  SEASONAL
  HIGH_POTENTIAL
  LOW_POTENTIAL
  NOT_ADVERTISING
  COMPETITOR_LOCKED
}

model Kontakt {
  id                String     @id @default(cuid())
  partnerId         String
  ime               String
  pozicija          String?
  email             String?
  telefon           String?
  primarni          Boolean    @default(false)
  legalBasis        LegalBasis @default(LEGITIMATE_INTEREST)
  izvor             String?
  pseudonimizovan   Boolean    @default(false)
  pseudonimizovanAt DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?

  partner    Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  aktivnosti Aktivnost[]

  @@index([partnerId])
  @@index([email])
}

enum LegalBasis {
  CONSENT
  CONTRACT
  LEGITIMATE_INTEREST
  LEGAL_OBLIGATION
}

model Aktivnost {
  id              String       @id @default(cuid())
  partnerId       String?
  kontaktId       String?
  opportunityId   String?
  tip             AktivnostTip
  datum           DateTime
  opis            String
  ishod           String?
  nextActionDatum DateTime?
  nextActionOpis  String?
  autorId         String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  partner     Partner?     @relation(fields: [partnerId], references: [id])
  kontakt     Kontakt?     @relation(fields: [kontaktId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  autor       Korisnik     @relation(fields: [autorId], references: [id])

  @@index([partnerId])
  @@index([opportunityId])
  @@index([autorId, datum])
}

enum AktivnostTip {
  POZIV
  SASTANAK
  MAIL
  FOLLOW_UP
  PONUDA
  POSETA
  OSTALO
}

// =============================================================
// Pipeline
// =============================================================

model Opportunity {
  id                String    @id @default(cuid())
  pravnoLiceId      String
  naziv             String
  partnerId         String
  kontaktId         String?
  vlasnikId         String
  stageId           String
  kategorijaId      String? // FK ka KategorijaDelatnosti — za vezu sa godišnjim planom
  probability       Int // override; default iz Stage
  izvor             OppIzvor  @default(OUTBOUND)
  tip               OppTip    @default(NEW)
  valuta            String
  expValue          Decimal   @db.Decimal(12, 2) // očekivana vrednost najbliže realizacije
  potencijal        Decimal?  @db.Decimal(12, 2) // dugoročni novčani potencijal klijenta
  potencijalDoDatum DateTime? // do kog datuma se realno može iskoristiti potencijal
  expCloseDate      DateTime
  realizacijaMesec  Int? // 1-12 za forecast
  realizacijaGodina Int?
  lostReasonId      String?
  lostReasonText    String? // samo za LOST kada je razlog OSTALO
  tags              String[]
  opis              String?
  stageUpdatedAt    DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  closedAt          DateTime?
  deletedAt         DateTime?

  pravnoLice  PravnoLice            @relation(fields: [pravnoLiceId], references: [id])
  partner     Partner               @relation(fields: [partnerId], references: [id])
  vlasnik     Korisnik              @relation("OpportunityVlasnik", fields: [vlasnikId], references: [id])
  stage       Stage                 @relation(fields: [stageId], references: [id])
  lostReason  LostReason?           @relation(fields: [lostReasonId], references: [id])
  kategorija  KategorijaDelatnosti? @relation(fields: [kategorijaId], references: [id])
  aktivnosti  Aktivnost[]
  kampanja    Kampanja?
  rezervacije Rezervacija[]
  dokumenti   Dokument[]

  @@index([pravnoLiceId, stageId])
  @@index([vlasnikId])
  @@index([expCloseDate])
  @@index([kategorijaId])
}

enum OppIzvor {
  INBOUND
  OUTBOUND
  REFERRAL
  EXISTING_CLIENT
  AGENCY
}

enum OppTip {
  NEW
  RENEWAL
  UPSELL
}

model Stage {
  id                 String   @id @default(cuid())
  kod                StageKod @unique
  naziv              String
  defaultProbability Int
  redosled           Int
  aktivan            Boolean  @default(true)

  opportunities Opportunity[]
}

enum StageKod {
  LEAD
  CONTACTED
  NEW
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  VERBALLY_CONFIRMED
  WON
  LOST
}

model LostReason {
  id      String        @id @default(cuid())
  kod     LostReasonKod @unique
  naziv   String
  aktivan Boolean       @default(true)

  opportunities Opportunity[]
}

enum LostReasonKod {
  CENA
  KONKURENCIJA
  TIMING
  BEZ_ODLUKE
  DUPLIKAT
  AGENCIJA
  BUDZET_NIJE_ODOBREN
  OSTALO
}

// =============================================================
// Inventar
// =============================================================

model Vozilo {
  id                      String       @id @default(cuid())
  pravnoLiceId            String
  // bcMediaBox kolone:
  sifra                   String? // "Šifra" — IMG interna šifra
  dobavljac               String? // "Dobavljač" — operator prevoza (npr. JKP GSP BEOGRAD)
  tipVozilaTxt            String? // "Tip vozila" — tekstualni (npr. Tramvaj solo KT4, Autobus zglobni)
  registracija            String // "Registarski broj"
  inventurniBroj          String? // "Inventurni broj" — garažni/inventarni broj
  oznaka                  String? // "Oznaka"
  garaza                  String? // "Garaža" (GSP Centrala, Dorćol, Karaburma, Zemun, Kosmaj, Novi Beograd)
  linija                  String[]     @default([]) // "Linija" — npr. "BG, 56 ZELENI VENAC - PETLOVO BRDO"
  zakupOd                 DateTime? // "Od"
  zakupDo                 DateTime? // "Do"
  aktivan                 Boolean      @default(true) // "Aktivan"
  model                   String? // "Model" (Solaris Urbino 18, Mercedes Citaro…)
  gps                     Boolean      @default(false) // "GPS"
  opis                    String? // "Opis" — (U ZAKUPU, U ZAKUPU / neaktivan; kvar, ŠIHTA…)
  brojUgovora             String? // "Broj ugovora"
  komNaknadaDatumDo       DateTime? // legacy "Kom.naknada (Datum do)"
  // Skice (slike) za prodajne ponude i logistiku:
  skicaSpoljnaUrl         String? // skica/foto vozila spolja sa pozicijama brendinga
  skicaUnutrasnjaUrl      String? // skica/foto unutrašnjosti sa pozicijama plakata
  // Digital posebni podaci (ako vozilo ima INDOOR_DIGITAL ekrane):
  routerBroj              String? // serijski / inventarni broj router-a
  kameraBroj              String? // serijski / inventarni broj kamere
  // Tipovi brendinga koje ovo vozilo PODRŽAVA (multi-select)
  podrzaniTipoviBrendinga TipOglasa[]  @default([])
  // Postojeća IMG polja:
  tip                     VoziloTip
  agencijaVlasnikId       String?
  zemlja                  String
  grad                    String
  slikaUrl                String?
  status                  VoziloStatus @default(AKTIVNO)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  deletedAt               DateTime?

  pravnoLice         PravnoLice           @relation(fields: [pravnoLiceId], references: [id])
  pozicije           Pozicija[]
  komunalneNaknade   KomunalnaNaknada[]
  ceneZakupa         VoziloCenaZakupa[]
  ponudaStavke       PonudaStavka[]
  NalogMontazuStavka NalogMontazuStavka[]

  @@unique([pravnoLiceId, registracija])
  @@index([grad])
  @@index([pravnoLiceId, garaza])
  @@index([pravnoLiceId, inventurniBroj])
}

// Cena zakupa po tipu brendinga per vozilu (zameni "Kom.naknada" pojam)
model VoziloCenaZakupa {
  id           String       @id @default(cuid())
  voziloId     String
  tipBrendinga TipOglasa
  cena         Decimal      @db.Decimal(12, 2)
  valuta       String
  jedinicaMere JedinicaMere @default(PER_WEEK)
  napomena     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  vozilo Vozilo @relation(fields: [voziloId], references: [id], onDelete: Cascade)

  @@unique([voziloId, tipBrendinga])
  @@index([voziloId])
}

enum VoziloTip {
  BUS
  BUS_ZGLOBNI
  MINI
  TRAMVAJ
  TROLEJBUS
  DRUGO
}

enum VoziloStatus {
  AKTIVNO
  U_ZAKUPU
  SERVIS
  KVAR
  NA_FARBANJU
  POVUCENO
  SIHTA
}

model Pozicija {
  id            String      @id @default(cuid())
  voziloId      String
  tip           PozicijaTip
  dimenzije     String?
  minPeriodDana Int         @default(7)
  cenaPoPeriodu Decimal     @db.Decimal(10, 2)
  valuta        String

  vozilo         Vozilo           @relation(fields: [voziloId], references: [id], onDelete: Cascade)
  rezervacije    Rezervacija[]
  kampanjaStavke KampanjaStavka[]

  @@index([voziloId])
}

enum PozicijaTip {
  CELO_VOZILO
  ZADNJI_DEO
  BOK_LEVO
  BOK_DESNO
  UNUTRA
  DRUGO
}

model Rezervacija {
  id            String            @id @default(cuid())
  pozicijaId    String
  opportunityId String? // kada je HOLD
  kampanjaId    String? // kada je CONFIRMED/RUNNING
  status        RezervacijaStatus
  odDatum       DateTime
  doDatum       DateTime
  holdIstice    DateTime? // samo za HOLD
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  pozicija    Pozicija     @relation(fields: [pozicijaId], references: [id])
  opportunity Opportunity? @relation(fields: [opportunityId], references: [id])
  kampanja    Kampanja?    @relation(fields: [kampanjaId], references: [id])

  @@index([pozicijaId, odDatum, doDatum])
  @@index([status])
}

enum RezervacijaStatus {
  HOLD
  CONFIRMED
  RUNNING
  CANCELLED
  RELEASED
}

model KomunalnaNaknada {
  id             String         @id @default(cuid())
  voziloId       String
  odDatum        DateTime
  doDatum        DateTime
  iznos          Decimal        @db.Decimal(10, 2)
  valuta         String
  statusPlacanja StatusPlacanja @default(NEPLACENO)
  napomena       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  vozilo Vozilo @relation(fields: [voziloId], references: [id])

  @@index([voziloId])
  @@index([doDatum])
}

enum StatusPlacanja {
  NEPLACENO
  DELIMICNO
  PLACENO
}

// =============================================================
// Operativno: kampanje + stavke
// =============================================================

model Kampanja {
  id            String         @id @default(cuid())
  pravnoLiceId  String
  opportunityId String?        @unique
  partnerId     String
  naziv         String
  odDatum       DateTime
  doDatum       DateTime
  status        KampanjaStatus @default(POTVRDENA)
  valuta        String
  kreativaUrl   String?
  napomene      String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  pravnoLice  PravnoLice       @relation(fields: [pravnoLiceId], references: [id])
  opportunity Opportunity?     @relation(fields: [opportunityId], references: [id])
  partner     Partner          @relation(fields: [partnerId], references: [id])
  stavke      KampanjaStavka[]
  rezervacije Rezervacija[]
  dokumenti   Dokument[]

  @@index([pravnoLiceId, status])
  @@index([partnerId])
}

enum KampanjaStatus {
  POTVRDENA
  U_REALIZACIJI
  ZAVRSENA
  OTKAZANA
}

model KampanjaStavka {
  id         String   @id @default(cuid())
  kampanjaId String
  pozicijaId String
  odDatum    DateTime
  doDatum    DateTime
  cena       Decimal  @db.Decimal(10, 2)
  valuta     String

  kampanja       Kampanja         @relation(fields: [kampanjaId], references: [id], onDelete: Cascade)
  pozicija       Pozicija         @relation(fields: [pozicijaId], references: [id])
  dokumentStavke DokumentStavka[]

  @@index([kampanjaId])
  @@index([pozicijaId])
}

// =============================================================
// Finansije
// =============================================================

model Dokument {
  id            String         @id @default(cuid())
  pravnoLiceId  String
  tip           DokumentTip
  broj          String
  datum         DateTime
  rokPlacanja   DateTime?
  partnerId     String
  kampanjaId    String?
  ponudaId      String? // PZ Faze 1: "nema izgubljenih para" — svaki prihod ima vezu sa Ponudom
  opportunityId String? // i sa prilikom (Opportunity)
  podzbir       Decimal        @db.Decimal(12, 2)
  pdv           Decimal        @db.Decimal(12, 2)
  ukupno        Decimal        @db.Decimal(12, 2)
  valuta        String
  napomene      String?
  status        DokumentStatus @default(OTVOREN)
  placenoAt     DateTime? // datum kad je naplaćen
  stornoOdId    String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  pravnoLice    PravnoLice       @relation(fields: [pravnoLiceId], references: [id])
  partner       Partner          @relation(fields: [partnerId], references: [id])
  kampanja      Kampanja?        @relation(fields: [kampanjaId], references: [id])
  ponuda        Ponuda?          @relation(fields: [ponudaId], references: [id])
  opportunity   Opportunity?     @relation(fields: [opportunityId], references: [id])
  stavke        DokumentStavka[]
  handoffZapisi HandoffZapis[]
  stornoOd      Dokument?        @relation("DokumentStorno", fields: [stornoOdId], references: [id])
  stornoZa      Dokument?        @relation("DokumentStorno")

  @@unique([pravnoLiceId, tip, broj])
  @@index([pravnoLiceId, datum])
  @@index([partnerId])
}

enum DokumentTip {
  PREDRACUN
  FAKTURA
  AVANS
  STORNO
}

enum DokumentStatus {
  OTVOREN
  PLACEN
  DELIMICNO_PLACEN
  STORNIRAN
  OTKAZAN
}

model DokumentStavka {
  id               String  @id @default(cuid())
  dokumentId       String
  kampanjaStavkaId String?
  opis             String
  kolicina         Decimal @default("1") @db.Decimal(10, 2)
  jedinicnaCena    Decimal @db.Decimal(12, 2)
  popust           Decimal @default("0") @db.Decimal(5, 2)
  iznos            Decimal @db.Decimal(12, 2)

  dokument       Dokument        @relation(fields: [dokumentId], references: [id], onDelete: Cascade)
  kampanjaStavka KampanjaStavka? @relation(fields: [kampanjaStavkaId], references: [id])

  @@index([dokumentId])
}

model NumeracijaSkok {
  id           String      @id @default(cuid())
  pravnoLiceId String
  tip          DokumentTip
  godina       Int
  poslednjiRbr Int         @default(0)

  pravnoLice PravnoLice @relation(fields: [pravnoLiceId], references: [id])

  @@unique([pravnoLiceId, tip, godina])
}

model HandoffBatch {
  id           String        @id @default(cuid())
  pravnoLiceId String
  format       HandoffFormat
  odDatum      DateTime
  doDatum      DateTime
  status       HandoffStatus @default(QUEUED)
  brojZapisa   Int           @default(0)
  odredisteUrl String?
  error        String?
  retryCount   Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  pravnoLice PravnoLice     @relation(fields: [pravnoLiceId], references: [id])
  zapisi     HandoffZapis[]

  @@index([pravnoLiceId, status])
}

enum HandoffFormat {
  SRB_SEF
  MNE_STD
  HRV_FINA
  BIH_STD
}

enum HandoffStatus {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
}

model HandoffZapis {
  id         String @id @default(cuid())
  batchId    String
  dokumentId String
  payload    Json

  batch    HandoffBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  dokument Dokument     @relation(fields: [dokumentId], references: [id])

  @@index([batchId])
}

// =============================================================
// Cross-cutting
// =============================================================

model Notifikacija {
  id           String          @id @default(cuid())
  pravnoLiceId String
  korisnikId   String
  tip          NotifikacijaTip
  poruka       String
  linkUrl      String?
  procitano    Boolean         @default(false)
  createdAt    DateTime        @default(now())

  pravnoLice PravnoLice @relation(fields: [pravnoLiceId], references: [id])
  korisnik   Korisnik   @relation(fields: [korisnikId], references: [id], onDelete: Cascade)

  @@index([korisnikId, procitano])
}

enum NotifikacijaTip {
  OPP_DODELJEN
  FOLLOWUP_DOSPEO
  OPP_ZAPEO
  FORECAST_ISPOD_TARGETA
  STARA_INTERAKCIJA
  KAMPANJA_POTVRDENA
  KAMPANJA_ISTEKLA
  POZICIJA_REZERVISANA
  POZICIJA_OTPUSTENA
  KOMUNALNA_ISTEKLA
  VOZILO_DODANO
  PII_PRISTUP
  RADNI_NALOG_NOVI
  PLAN_FAKTURISANJA_NOVI
  PONUDA_PRIHVACENA
}

model AuditLog {
  id           String      @id @default(cuid())
  pravnoLiceId String?
  korisnikId   String?
  entitet      String
  entitetId    String
  akcija       AuditAkcija
  diff         Json?
  ip           String?
  userAgent    String?
  timestamp    DateTime    @default(now())

  pravnoLice PravnoLice? @relation(fields: [pravnoLiceId], references: [id])
  korisnik   Korisnik?   @relation(fields: [korisnikId], references: [id])

  @@index([entitet, entitetId])
  @@index([korisnikId])
  @@index([timestamp])
}

enum AuditAkcija {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  EXPORT
  STAGE_CHANGE
  HOLD_CREATE
  HOLD_RELEASE
  TENANT_OVERRIDE
  GDPR_ERASURE
  GDPR_ACCESS
  PERMISSION_CHANGE
  INVOICE_GENERATE
  HANDOFF_BATCH
}

model LicniPodatakPristup {
  id         String   @id @default(cuid())
  korisnikId String
  subjektTip String // "Kontakt", "Partner", ...
  subjektId  String
  svrha      String
  timestamp  DateTime @default(now())

  korisnik Korisnik @relation(fields: [korisnikId], references: [id])

  @@index([subjektTip, subjektId])
  @@index([korisnikId])
}

// =============================================================
// Sačuvani filteri (pipeline)
// =============================================================

model SacuvaniFilter {
  id         String @id @default(cuid())
  korisnikId String
  naziv      String
  modul      String // "pipeline" | "partners" | ...
  filterJson Json

  @@index([korisnikId, modul])
}

// =============================================================
// Prodaja: kategorije delatnosti, cenovnik, paketi, planovi
// =============================================================

model KategorijaDelatnosti {
  id           String  @id @default(cuid())
  pravnoLiceId String
  kod          String
  naziv        String
  opis         String?
  aktivna      Boolean @default(true)

  godisnjePlanStavke PlanRadaGodisnjiStavka[]
  opportunities      Opportunity[]

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId])
}

model Cenovnik {
  id           String       @id @default(cuid())
  pravnoLiceId String
  kod          String
  naziv        String
  opis         String?
  tipOglasa    TipOglasa
  jedinicaMere JedinicaMere @default(PER_WEEK)
  cena         Decimal      @db.Decimal(12, 2)
  valuta       String
  vaziOd       DateTime     @default(now())
  vaziDo       DateTime?
  aktivan      Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  paketi Paket[]

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId, tipOglasa])
}

enum TipOglasa {
  // === OUTDOOR (spoljašnji branding) ===
  OUTDOOR_FULL_BRANDING
  OUTDOOR_STANDARD_BRANDING
  OUTDOOR_PARCIJAL
  OUTDOOR_SUPER_PARCIJAL
  OUTDOOR_OPEN_TOP
  OUTDOOR_TOTAL // legacy alias

  // === INDOOR (unutrašnji formati) ===
  INDOOR_STANDARD
  INDOOR_OSVETLJENI_PANO
  INDOOR_BACKLIGHT // legacy alias
  INDOOR_DIGITAL
  INDOOR_POSTER // legacy alias

  // === DODATNI FORMATI ===
  DODATAK_HENGER_STANDARD
  DODATAK_HENGER_NESTANDARD
  DODATAK_VOBLER
  DODATAK_RUCKE_VALJKASTE
  DODATAK_RUCKE_PLJOSNATE
  DODATAK_BLENDIRANJE_PLAFONA
  DODATAK_NALEPNICE_SEDISTA

  DIGITAL
  KOMUNALNA
  OSTALO
}

enum JedinicaMere {
  PER_DAY
  PER_WEEK
  PER_MONTH
  PER_CAMPAIGN
}

model Paket {
  id              String    @id @default(cuid())
  pravnoLiceId    String
  kod             String
  naziv           String
  opis            String?
  grad            String
  tipOglasa       TipOglasa
  brojVozila      Int
  minTrajanjeDana Int       @default(14)
  cena            Decimal   @db.Decimal(12, 2)
  valuta          String
  cenovnikId      String?
  aktivan         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cenovnik Cenovnik? @relation(fields: [cenovnikId], references: [id])

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId, grad])
}

model PlanRadaGodisnji {
  id           String   @id @default(cuid())
  pravnoLiceId String
  korisnikId   String // vlasnik plana (prodavac)
  godina       Int
  napomena     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  stavke PlanRadaGodisnjiStavka[]

  @@unique([pravnoLiceId, korisnikId, godina])
  @@index([korisnikId])
}

model PlanRadaGodisnjiStavka {
  id           String  @id @default(cuid())
  planId       String
  kategorijaId String
  mesec        Int // 1-12
  target       Decimal @db.Decimal(12, 2)
  valuta       String

  plan       PlanRadaGodisnji     @relation(fields: [planId], references: [id], onDelete: Cascade)
  kategorija KategorijaDelatnosti @relation(fields: [kategorijaId], references: [id])

  @@unique([planId, kategorijaId, mesec])
  @@index([planId])
}

model PlanRadaDnevni {
  id             String   @id @default(cuid())
  pravnoLiceId   String
  korisnikId     String
  datum          DateTime @db.Date
  opis           String // slobodan tekst: pozivi, ponude, sastanci, izveštaji, naplate
  analizaTrzista String? // slobodan tekst
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([korisnikId, datum])
  @@index([pravnoLiceId, datum])
}

// =============================================================
// Logistika: Radni nalog (kreira se iz WON ponude)
// =============================================================

model RadniNalog {
  id                String           @id @default(cuid())
  pravnoLiceId      String
  broj              String
  opportunityId     String?          @unique
  kampanjaId        String?          @unique
  partnerId         String
  vlasnikProdajaId  String
  logistikaId       String?
  status            RadniNalogStatus @default(NOVO)
  odDatum           DateTime
  doDatum           DateTime
  grad              String?
  predlogLinija     String? // npr "TROLAx3; KT4x3; CAFx3; 16, 17, 18, 23x2..."
  brojVozilaPoGradu Json? // {"Beograd": 30, "Niš": 5, ...}
  napomena          String?
  kreativaUrl       String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  // Logistika workflow djeca
  nalogMontazu  NalogMontazu[]
  nalogStampu   NalogStampu[]
  resenja       Resenje[]
  fotoAlbumi    FotoAlbum[]
  postbrendinzi Postbrending[]

  @@unique([pravnoLiceId, broj])
  @@index([pravnoLiceId, status])
  @@index([partnerId])
}

enum RadniNalogStatus {
  NOVO
  PRIHVACEN_LOGISTIKA
  PRIPREMA_MONTAZE
  U_REALIZACIJI
  ZAVRSEN
  OTKAZAN
}

// =============================================================
// Logistika workflow: Rešenja, Nalog za Montažu, Nalog za Štampu, Foto, Postbrending
// =============================================================

// Rešenja (R01, R02, R03 sa raspodelom %)
model Resenje {
  id           String  @id @default(cuid())
  radniNalogId String
  oznaka       String // "R01", "R02", "R03"
  naziv        String? // opciono ime kreative
  procenat     Decimal @default("100") @db.Decimal(5, 2) // npr 50 za 50%
  napomena     String?

  radniNalog    RadniNalog           @relation(fields: [radniNalogId], references: [id], onDelete: Cascade)
  montazaStavke NalogMontazuStavka[]
  stampaStavke  NalogStampuStavka[]

  @@unique([radniNalogId, oznaka])
  @@index([radniNalogId])
}

// Nalog za Montažu — Beograd ili Gradovi
model NalogMontazu {
  id             String            @id @default(cuid())
  pravnoLiceId   String
  radniNalogId   String
  broj           String // 317-TELENOR-MONTAZA-BG ili "125-2026"
  tip            NalogMontazuTip
  grad           String? // za GRADOVI: konkretan grad
  ekipa          String? // legacy free-text (zadržano kompatibilnosti radi)
  montazerId     String? // FK ka Montazer (BUS BRANDING…)
  prevoznikNaziv String? // "Niš ekspres" — slobodno polje
  masinaId       String? // FK ka Masina (LATEX…)
  datumMontaze   DateTime?
  vremeMontaze   String? // "08:00", "od 06h"
  status         NalogStavkaStatus @default(NACRT)
  napomena       String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  radniNalog  RadniNalog           @relation(fields: [radniNalogId], references: [id], onDelete: Cascade)
  montazerRef Montazer?            @relation(fields: [montazerId], references: [id])
  masinaRef   Masina?              @relation(fields: [masinaId], references: [id])
  stavke      NalogMontazuStavka[]

  @@unique([pravnoLiceId, broj])
  @@index([radniNalogId])
  @@index([montazerId])
  @@index([masinaId])
}

enum NalogMontazuTip {
  BEOGRAD
  GRADOVI
}

enum NalogStavkaStatus {
  NACRT
  POSLATO
  POSTAVLJENO
  PROBLEM
  OTKAZANO
}

// Stavka u nalogu za montažu — konkretan vozilo + raspored plakata
model NalogMontazuStavka {
  id             String  @id @default(cuid())
  nalogId        String
  redniBr        Int? // 1, 2, 3 …
  voziloId       String?
  garazniBroj    String? // ako vozilo nije u sistemu
  garaza         String? // GSP Centrala / Dorćol / Karaburma...
  linija         String? // 16, 56, slob...
  tipVozila      String? // Solaris / KT4 / CAF...
  resenjeId      String?
  // Raspored plakata: npr "1+8" (1 iza vozača + 8 kosina), "7" (7 vertikala KT4)
  sifraRasporeda String?
  // Brojevi panoa po dimenziji (Json — fleksibilno)
  brojPanoa      Json? // {"46x80 folija": 1, "79x37 folija": 8, "47x77 sv": 5}

  // Iz primera nalog za montažu.xlsx
  skidanjeM2   Decimal? @db.Decimal(8, 2) // skidanje prethodne reklame, m²
  montazaM2    Decimal? @db.Decimal(8, 2) // površina nove montaže, m²
  rnStamparije String? // RN broj koji je vratila štamparija

  status        NalogStavkaStatus @default(NACRT)
  postavljenoAt DateTime?
  napomena      String?
  problemTip    String? // "autobus nije došao", "zaključan", "farbanje"...

  nalog   NalogMontazu @relation(fields: [nalogId], references: [id], onDelete: Cascade)
  vozilo  Vozilo?      @relation(fields: [voziloId], references: [id])
  resenje Resenje?     @relation(fields: [resenjeId], references: [id])

  @@index([nalogId])
  @@index([voziloId])
}

// Nalog za Štampu — DPC Beograd ili Niš/druge štamparije
model NalogStampu {
  id            String            @id @default(cuid())
  pravnoLiceId  String
  radniNalogId  String
  broj          String
  kampanjaNaziv String? // "FAIRY HIGER - 2 kom"
  stamparija    StamparijaTip
  datumPredaje  DateTime
  rokIzrade     DateTime
  rokIzradeTime String? // "DO 14H"
  masinaId      String? // FK ka Masina (LATEX, HP, XEIKON…)
  masina        String? // legacy fallback string
  rnStamparije  String? // broj radnog naloga koji vrati štamparija
  status        NalogStavkaStatus @default(NACRT)
  napomena      String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  radniNalog RadniNalog          @relation(fields: [radniNalogId], references: [id], onDelete: Cascade)
  masinaRef  Masina?             @relation(fields: [masinaId], references: [id])
  stavke     NalogStampuStavka[]

  @@unique([pravnoLiceId, broj])
  @@index([radniNalogId])
  @@index([masinaId])
}

enum StamparijaTip {
  DPC_BEOGRAD
  STAMPARIJA_NIS
  DRUGA
}

enum MaterijalTip {
  FOLIJA_3M_IJ20
  PAPIR_130GR
  PAPIR_SV // svetleci
  PAPIR_DUPLEKS
  DRUGO
}

model NalogStampuStavka {
  id            String  @id @default(cuid())
  nalogId       String
  redniBr       Int? // 1, 2, 3 …
  grad          String // BG / NS / NI / KG / SU...
  resenjeId     String?
  resenjeOznaka String? // "R01" ako resenje nije FK
  simpleks      Boolean @default(true) // true = simpleks, false = dupleks

  // HIGER format kolona
  fileNaziv String? // "155X105 - RAM - HIG crv"
  formatX   Decimal? @db.Decimal(8, 2) // npr 155.00 cm
  formatY   Decimal? @db.Decimal(8, 2) // npr 105.00 cm

  // Backwards-compat: stari format string (i materijal enum) ostaju za stare zapise
  format    String // "46x80 ram" — održava se za legacy
  tiraz     Int
  materijal MaterijalTip
  gramatura String? // "130gr"

  // Lookup FK (novo)
  folijaId String?
  doradaId String?

  // Legacy
  dorada        String? // "secenje na format", "BEZ LAMINACIJE"
  cenaJedinicna Decimal? @db.Decimal(10, 2)
  cenaUkupno    Decimal? @db.Decimal(12, 2)
  napomena      String?

  nalog     NalogStampu @relation(fields: [nalogId], references: [id], onDelete: Cascade)
  resenje   Resenje?    @relation(fields: [resenjeId], references: [id])
  folijaRef Folija?     @relation(fields: [folijaId], references: [id])
  doradaRef Dorada?     @relation(fields: [doradaId], references: [id])

  @@index([nalogId])
  @@index([folijaId])
  @@index([doradaId])
}

// Cenovnik štampe (za auto-cost calculation pri kreiranju Naloga za Štampu)
model StamparijaCenovnik {
  id           String        @id @default(cuid())
  pravnoLiceId String
  stamparija   StamparijaTip
  format       String
  materijal    MaterijalTip
  cena         Decimal       @db.Decimal(10, 2)
  valuta       String
  vaziOd       DateTime      @default(now())
  vaziDo       DateTime?
  aktivan      Boolean       @default(true)

  @@index([pravnoLiceId, stamparija, format, materijal])
}

// Foto album — montaža + saobraćaj
model FotoAlbum {
  id           String       @id @default(cuid())
  pravnoLiceId String
  radniNalogId String
  naziv        String // "TELENOR — montaža BG", "TELENOR — saobraćaj"
  tip          FotoAlbumTip
  pdfUrl       String? // generisan PDF sa watermarkom
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  radniNalog  RadniNalog    @relation(fields: [radniNalogId], references: [id], onDelete: Cascade)
  fotografije Fotografija[]

  @@index([radniNalogId])
}

enum FotoAlbumTip {
  MONTAZA
  SAOBRACAJ
  POSTBRANDING
}

model Fotografija {
  id        String   @id @default(cuid())
  albumId   String
  url       String
  naziv     String?
  redosled  Int      @default(0)
  createdAt DateTime @default(now())

  album FotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@index([albumId])
}

// Postbrending — izveštaj klijentu po završenoj montaži
model Postbrending {
  id           String    @id @default(cuid())
  pravnoLiceId String
  radniNalogId String
  broj         String
  datum        DateTime  @default(now())
  fotoAlbumId  String?
  pdfUrl       String?
  poslatoAt    DateTime?
  napomena     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  radniNalog RadniNalog @relation(fields: [radniNalogId], references: [id], onDelete: Cascade)

  @@unique([pravnoLiceId, broj])
  @@index([radniNalogId])
}

// Default raspored plakata po tipu vozila (referenca za auto-popunjavanje montaža stavki)
model RasporedPlakata {
  id             String  @id @default(cuid())
  pravnoLiceId   String
  voziloTipKod   String // "SOLARIS_ZGLOBNI", "KT4", "CAF", "TROLEJBUS_321", "AUTOBUS_SOLO"
  naziv          String
  sifraRasporeda String // "1+8", "7", "1+10+8"
  // Po dimenzijama (npr [{format: "46x80", broj: 1, tip: "FOLIJA"}, ...])
  panoi          Json
  ukupnoPovrsina Int
  napomena       String?

  @@unique([pravnoLiceId, voziloTipKod])
  @@index([pravnoLiceId])
}

// =============================================================
// Šifarnici / Lookup tabele za logistiku (Outdoor + štampa + montaža)
// =============================================================

// Predefinisani paketi vozila za Beograd parcial branding (5/10/20 vozila × 10 paketa = 30)
model PaketVozila {
  id           String  @id @default(cuid())
  pravnoLiceId String
  kod          String // "PAKET_5_VOZ_7"
  naziv        String // "5 Vozila - Paket 7"
  brojVozila   Int
  sastav       String // "1 x KT4, 2 x solo bus (27E, 44), 2 x zglobni bus (85, 95)"
  napomena     String?
  aktivan      Boolean @default(true)

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId])
}

// Folije za štampu — AVERY 3001 HOP, MACtac, …
model Folija {
  id                String              @id @default(cuid())
  pravnoLiceId      String
  kod               String // "AVERY_3001_HOP"
  naziv             String // "AVERY 3001 HOP"
  napomena          String?
  aktivan           Boolean             @default(true)
  NalogStampuStavka NalogStampuStavka[]

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId])
}

// Dorada — print & cut, cut + transfer, laminacija, BEZ LAMINACIJE …
model Dorada {
  id                String              @id @default(cuid())
  pravnoLiceId      String
  kod               String // "PRINT_CUT"
  naziv             String // "print & cut"
  napomena          String?
  aktivan           Boolean             @default(true)
  NalogStampuStavka NalogStampuStavka[]

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId])
}

// Mašina za štampu — LATEX, HP, XEIKON, ECO-SOLVENT …
model Masina {
  id           String         @id @default(cuid())
  pravnoLiceId String
  kod          String // "LATEX"
  naziv        String // "LATEX"
  napomena     String?
  aktivan      Boolean        @default(true)
  NalogMontazu NalogMontazu[]
  NalogStampu  NalogStampu[]

  @@unique([pravnoLiceId, kod])
  @@index([pravnoLiceId])
}

// Montažer / ekipa za lepljenje — BUS BRANDING …
model Montazer {
  id           String         @id @default(cuid())
  pravnoLiceId String
  naziv        String // "BUS BRANDING"
  kontakt      String?
  email        String?
  telefon      String?
  napomena     String?
  aktivan      Boolean        @default(true)
  NalogMontazu NalogMontazu[]

  @@index([pravnoLiceId])
}

// Putni trošak — BG ↔ grad sa km i cenom (lookup)
model PutniTrosak {
  id           String  @id @default(cuid())
  pravnoLiceId String
  gradOd       String // "BG"
  gradDo       String // "NS"
  kmJedanSmer  Int
  cenaUkupno   Decimal @db.Decimal(12, 2)
  valuta       String // "RSD"
  napomena     String?
  aktivan      Boolean @default(true)

  @@unique([pravnoLiceId, gradOd, gradDo])
  @@index([pravnoLiceId])
}

// =============================================================
// Finansije: Plan fakturisanja (iz WON sa split-om po mesecima)
// =============================================================

model PlanFakturisanja {
  id               String                 @id @default(cuid())
  pravnoLiceId     String
  broj             String
  opportunityId    String?                @unique
  kampanjaId       String?                @unique
  partnerId        String
  vlasnikProdajaId String // menadžer prodaje
  valuta           String
  grad             String?
  tipOglasa        TipOglasa?
  brojVozila       Int?
  status           PlanFakturisanjaStatus @default(NACRT)
  ukupno           Decimal                @db.Decimal(14, 2)
  kampanjaOd       DateTime
  kampanjaDo       DateTime
  napomena         String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  stavke PlanFakturisanjaStavka[]

  @@unique([pravnoLiceId, broj])
  @@index([partnerId])
  @@index([pravnoLiceId, status])
}

enum PlanFakturisanjaStatus {
  NACRT
  POTVRDENO
  FAKTURISANO
  OTKAZAN
}

// =============================================================
// Prodaja: Ponuda (formalni dokument izvučen iz Opportunity)
// =============================================================

model Ponuda {
  id            String       @id @default(cuid())
  pravnoLiceId  String
  broj          String
  opportunityId String?      @unique
  partnerId     String
  vlasnikId     String
  datum         DateTime     @default(now())
  vaziDo        DateTime
  status        PonudaStatus @default(DRAFT)
  poslataAt     DateTime?
  prihvacenaAt  DateTime?
  odbijenaAt    DateTime?
  valuta        String
  ukupno        Decimal      @db.Decimal(14, 2)
  stopaPdv      Decimal      @default("20") @db.Decimal(5, 2)
  napomena      String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  stavke    PonudaStavka[]
  dokumenti Dokument[]

  @@unique([pravnoLiceId, broj])
  @@index([partnerId])
  @@index([pravnoLiceId, status])
  @@index([vaziDo])
}

enum PonudaStatus {
  DRAFT
  POSLATA
  PRIHVACENA
  ODBIJENA
  ISTEKLA
}

model PonudaStavka {
  id           String     @id @default(cuid())
  ponudaId     String
  rb           Int
  opis         String
  grad         String?
  brojVozila   Int        @default(1)
  cena         Decimal    @db.Decimal(12, 2)
  popustPct    Decimal    @default("0") @db.Decimal(5, 2)
  iznos        Decimal    @db.Decimal(14, 2)
  valuta       String
  tipBrendinga TipOglasa?
  skicaUrl     String?
  voziloId     String?

  ponuda Ponuda  @relation(fields: [ponudaId], references: [id], onDelete: Cascade)
  vozilo Vozilo? @relation(fields: [voziloId], references: [id])

  @@index([ponudaId])
  @@index([voziloId])
}

model PlanFakturisanjaStavka {
  id          String  @id @default(cuid())
  planId      String
  mesec       Int // 1-12
  godina      Int
  iznos       Decimal @db.Decimal(14, 2)
  valuta      String
  dokumentId  String? // referenca kad se fakturiše
  fakturisano Boolean @default(false)

  plan PlanFakturisanja @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, godina, mesec])
  @@index([planId])
}
